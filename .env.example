# Capital.com API Configuration
CAPITALCOM_API_KEY=your-capitalcom-api-key-here
CAPITALCOM_IDENTIFIER=your-email@example.com
CAPITALCOM_PASSWORD=your-password-here
CAPITALCOM_ENVIRONMENT=demo

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_ENABLED=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret-key

# Trading Mode
TRADING_MODE=paper

# CORS (optional, comma-separated origins for external access)
# ALLOWED_ORIGINS=http://your-server-ip:8000
